\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{unithesis}[2026/06/01 Ukrainian Master Thesis Style v1.0]

%% ── Кодування та мова ───────────────────────────────────────
\RequirePackage[T2A]{fontenc}
\RequirePackage[utf8]{inputenc}
\RequirePackage[ukrainian,english]{babel}

%% ── Шрифт ───────────────────────────────────────────────────
\IfFileExists{tempora.sty}{\RequirePackage{tempora}}{%
  \PackageWarning{unithesis}{tempora.sty not found, using CM Roman}}

%% ── Перший абзац теж з відступом (ДСТУ) ─────────────────────
\RequirePackage{indentfirst}

%% ── Заборона переносів ──────────────────────────────────────
\tolerance=1
\emergencystretch=\maxdimen
\hyphenpenalty=10000
\exhyphenpenalty=10000

%% ── Менше шуму у log (underfull h/vbox @ badness ≤ 10000) ───
%% Видно лише дійсно проблемні випадки. Прибрати — поставити 1000.
\hbadness=10000
\vbadness=10000

%% Поля (ДСТУ)
\RequirePackage[left=3cm, right=2cm, top=2cm, bottom=2cm]{geometry}
\RequirePackage{setspace}
\onehalfspacing
\setdisplayskipstretch{1.0}
\setlength{\parindent}{1.25cm}
\setlength{\parskip}{0pt}

%% ── Колонтитули ─────────────────────────────────────────────
\RequirePackage{fancyhdr}
\setlength{\headheight}{17pt}
\addtolength{\topmargin}{-3pt}
\pagestyle{fancy}
\fancyhf{}
\fancyhead[R]{\thepage}
\renewcommand{\headrulewidth}{0pt}
\fancypagestyle{plain}{%
  \fancyhf{}\fancyhead[R]{\thepage}%
  \renewcommand{\headrulewidth}{0pt}}

%% ── Заголовки (ДСТУ) ────────────────────────────────────────
\RequirePackage{titlesec}
\titleformat{\chapter}[block]
  {\normalfont\fontsize{14pt}{16pt}\bfseries\centering}
  {\chaptertitlename\ \thechapter.}{0.5em}{\MakeUppercase}
\titlespacing*{\chapter}{0pt}{0pt}{14pt}
\titleformat{\section}
  {\normalfont\fontsize{14pt}{16pt}\bfseries}{\thesection}{0.5em}{}
\titlespacing*{\section}{0pt}{14pt}{7pt}
\titleformat{\subsection}
  {\normalfont\fontsize{14pt}{16pt}\bfseries\itshape}{\thesubsection}{0.5em}{}
\titlespacing*{\subsection}{0pt}{10pt}{4pt}

%% ── Зміст ───────────────────────────────────────────────────
\RequirePackage{tocloft}
\renewcommand{\cfttoctitlefont}{\hfill\bfseries\MakeUppercase}
\renewcommand{\cftaftertoctitle}{\hfill}
\renewcommand{\cftchapfont}{\bfseries}
\renewcommand{\cftchapleader}{\cftdotfill{\cftdotsep}}
\setlength{\cftbeforechapskip}{4pt}
%% Прибрати велике відступлення зверху перед заголовком ЗМІСТ.
%% tocloft за замовчуванням ставить ~1in перед заголовком — підтягуємо вгору.
\setlength{\cftbeforetoctitleskip}{0pt}
\setlength{\cftaftertoctitleskip}{14pt}

%% ── Графіка ─────────────────────────────────────────────────
\RequirePackage{graphicx}
\RequirePackage{float}
\RequirePackage{booktabs}
\RequirePackage{longtable}
\RequirePackage{array}      %% \newcolumntype, >{...}, <{...}
\RequirePackage{tabularx}   %% tabularx env + X-колонки

%% Y — це X-колонка з ragged-right (без розтягування пробілів).
%% Використовується у \snippet{}-таблицях для повної ширини на текст:
%%   \begin{tabularx}{\linewidth}{|Y|Y|Y|}...\end{tabularx}
\newcolumntype{Y}{>{\raggedright\arraybackslash}X}

%% Z{w} — раггед-X-колонка з ВІДНОСНОЮ шириною.
%% Сума ваг у всіх Z-колонках має дорівнювати ЧИСЛУ колонок:
%%   3 колонки 25%/50%/25%  →  Z{0.75} Z{1.5} Z{0.75}    (сума = 3)
%%   4 колонки 40%/20%/20%/20%  →  Z{1.6} Z{0.8} Z{0.8} Z{0.8}  (сума = 4)
\newcolumntype{Z}[1]{>{\hsize=#1\hsize\linewidth=\hsize\raggedright\arraybackslash}X}

%% Підписи
\RequirePackage{caption}
\RequirePackage{subcaption}
\DeclareCaptionLabelSeparator{endash}{ -- }

%% Рисунки: по центру, знизу
\captionsetup{
  labelsep        = endash,
  justification   = centering,
  font            = normalsize,
  position        = below,
}
%% Таблиці (table env): праворуч, зверху
\captionsetup[table]{
  labelsep        = endash,
  justification   = raggedleft,
  singlelinecheck = false,
  font            = normalsize,
  position        = above,
  skip            = 2pt,
}
%% longtable (markdown pipe tables → longtable): теж праворуч, зверху
\captionsetup[longtable]{
  labelsep        = endash,
  justification   = raggedleft,
  singlelinecheck = false,
  font            = normalsize,
  position        = above,
  skip            = 2pt,
}
%% Лістинги: по центру, знизу
\captionsetup[lstlisting]{
  labelsep        = endash,
  justification   = centering,
  font            = normalsize,
  position        = below,
}

\graphicspath{{assets/images/}}

%% Списки
\RequirePackage{enumitem}
\setlist{topsep=0pt, partopsep=0pt, parsep=0pt, itemsep=0pt}
\setlist[itemize]{
  label      = {\normalfont--},
  leftmargin = 0pt,
  itemindent = \parindent,
}
\setlist[enumerate]{
  leftmargin = 0pt,
  itemindent = \parindent,
}

%% Математика
\RequirePackage{amsmath,amssymb,amsthm,mathtools}
\theoremstyle{plain}
\newtheorem{theorem}{Теорема}[chapter]
\newtheorem{lemma}[theorem]{Лема}
\theoremstyle{definition}
\newtheorem{definition}{Визначення}[chapter]
\newtheorem{remark}{Зауваження}[chapter]

%% Пояснення параметрів формули без абзацного відступу.
%% Через порожній рядок у markdown пояснення стає НОВИМ абзацом і
%% отримує \parindent. \where прибирає цей відступ:
%%   \begin{equation}...\end{equation}
%%
%%   \where де $I$ -- вхідне зображення, $K$ -- ядро згортки.
\newcommand{\where}{\noindent\ignorespaces}

%% ── TikZ та pgfplots ────────────────────────────────────────
\RequirePackage{tikz}
\RequirePackage{pgfplots}
\pgfplotsset{compat=1.18}
\usetikzlibrary{positioning,arrows.meta,calc,shapes.geometric}

%% ── Лістинги ────────────────────────────────────────────────
%% Шрифт 10pt + автоматичний перенос довгих рядків.
%% Маркер ↪ показує, що рядок продовжується.
\RequirePackage{listings,xcolor}
\definecolor{lst-bg}     {RGB}{248,248,248}
\definecolor{lst-comment}{RGB}{0,128,0}
\definecolor{lst-keyword}{RGB}{0,0,180}
\definecolor{lst-string} {RGB}{180,80,0}
\definecolor{lst-number} {RGB}{120,120,120}
\definecolor{lst-break}  {RGB}{180,0,0}
\lstdefinestyle{thesis}{
  backgroundcolor   = \color{lst-bg},
  commentstyle      = \color{lst-comment},
  keywordstyle      = \color{lst-keyword}\bfseries,
  numberstyle       = \tiny\color{lst-number},
  stringstyle       = \color{lst-string},
  basicstyle        = \fontsize{10pt}{12pt}\selectfont\ttfamily,
  breaklines        = true,
  breakatwhitespace = false,
  breakindent       = 1.5em,
  postbreak         = \mbox{\textcolor{lst-break}{$\hookrightarrow$}\space},
  columns           = fullflexible,
  keepspaces        = true,
  numbers           = left,
  numbersep         = 8pt,
  frame             = single,
  framerule         = 0.4pt,
  framexleftmargin  = 0pt,
  xleftmargin       = 0pt,
  xrightmargin      = 0pt,
  tabsize           = 4,
  captionpos        = b,
  extendedchars     = false,   %% pdfLaTeX: тільки латиниця у коді
}
\lstset{style=thesis}

%% ── \codefile{path}{lang}{caption}{label} ───────────────────
%% Інжектує файл коду НАПРЯМУ (без .tex-обгортки). Успадковує
%% style=thesis: автоматичний перенос довгих рядків, шрифт 10pt,
%% нумерація рядків, маркер ↪ продовження.
%%
%% Приклад у .md:
%%   \codefile{code/train.py}{Python}{Модуль навчання моделі}{lst:train}
%%
%% catcode-трюк потрібен, бо markdown (hybrid=true) "з'їдає" `_`, `#`, `%`
%% у аргументах команд.
\newcommand{\codefile}[4]{%
  \begingroup
    \catcode`\%=14
    \catcode`\_=8
    \catcode`\#=6
    \lstinputlisting[language=#2, caption={#3}, label={#4}]{#1}%
  \endgroup
}

%% ── \snippet{file.tex} ──────────────────────────────────────
%% Для lstlisting, tikz і будь-якого складного LaTeX у .md файлах.
%\newcommand{\snippet}[1]{\input{assets/snippets/#1}}
\newcommand{\snippet}[1]{%
  \begingroup
    \catcode`\%=14   % `%` знову є коментарем
    \catcode`\_=8    % `_` знову є subscript-only-in-math
    \catcode`\#=6    % `#` знову є параметром
    \input{assets/snippets/#1}%
  \endgroup
}

%% ── Markdown ────────────────────────────────────────────────
%%
%%  pipeTables + tableCaptions → markdown таблиці:
%%    | Назва | Значення |      → longtable
%%    |-------|----------|
%%    | а     | б        |
%%    : Підпис таблиці\label{tbl:label}    ← \label{} ВСЕРЕДИНІ caption
%%
%%  hybrid=true → \ref{}, \eqref{}, \snippet{} у .md
%%  Markdown 3.13 видає попередження про deprecated `hybrid` через
%%  \markdownWarning (не через \PackageWarning), тому silence package
%%  не допомагає. Глушимо безпосередньо у \AtBeginDocument нижче.
%%
%%  rawAttribute ВИМКНЕНО: markdown 3.x обгортає raw-блоки
%%  у verbatim і ламає & у таблицях і \\ у lstlisting.
%%
\RequirePackage{markdown}
\markdownSetup{
  hybrid         = true,
  texMathDollars = true,
  citations      = true,
  pipeTables     = true,
  tableCaptions  = true,
  fencedCode     = true,
  renderers = {
    headingOne   = {\chapter{#1}},
    headingTwo   = {\section{#1}},
    headingThree = {\subsection{#1}},
    headingFour  = {\subsubsection{#1}},
  }
}

%% ── Таблиці: заголовок ЗВЕРХУ + повна горизонтальна сітка ───
%% Стандартний прототип markdown ставить \caption{} після \end{tabular}.
%% Перевизначаємо: \caption{} іде між \begin{table} і \begin{tabular},
%% що відповідає ДСТУ та captionsetup[table]{position=above}.
%%
%% Додатково: правила booktabs (\toprule/\midrule/\bottomrule) замінено
%% на \hline, а між кожним рядком ставиться \hline → повна горизонтальна
%% сітка, як у класичних таблицях ДСТУ.
%%
%% Структура результату:
%%   \begin{table}[H]
%%     \caption{Назва}\label{...}
%%     \centering
%%     \begin{tabular}{...}
%%       \hline ...header... \\ \hline
%%       ...row... \\ \hline
%%       ...
%%     \end{tabular}
%%   \end{table}
%%
%% ПРИМІТКА про ширину та вертикальні лінії:
%%   markdown сам генерує специфікацію колонок ({llll}), тому колонки
%%   мають ширину за вмістом і без вертикальних роздільників. Спроби
%%   "ззовні" замінити \begin{tabular}{...} на \begin{tabularx}{...}{...}
%%   ламають аргумент. Якщо для конкретної таблиці потрібна ширина на
%%   всю сторінку та/або вертикальні лінії — використайте \snippet{}
%%   із власноруч написаним tabularx (приклад у chapters/tables/).
\markdownSetup{rendererPrototypes={
  table = {%
    \markdownLaTeXTable={}%
    \markdownLaTeXTableAlignment={}%
    \markdownLaTeXTableEnd={%
      \end{tabular}}%
    \ifx\empty#1\empty\else
      \addto@hook\markdownLaTeXTable{\begin{table}[H]}%
      \addto@hook\markdownLaTeXTable{\caption{#1}\centering}%
      \addto@hook\markdownLaTeXTableEnd{\end{table}}%
    \fi
    %% Заглушуємо booktabs-правила: top/mid/bottom rule → \hline.
    %% Початковий \hline дає рамку зверху; \markdownLaTeXTopRule стане
    %% \hline у самому початку tabular.
    \let\markdownLaTeXTopRule\hline
    \let\markdownLaTeXMidRule\hline
    \let\markdownLaTeXBottomRule\hline
    %% Між рядками — теж \hline. \markdownLaTeXRowEnd використовується
    %% наприкінці кожного рядка.
    \def\markdownLaTeXRowEnd{\\\hline}%
    \addto@hook\markdownLaTeXTable{\begin{tabular}}%
    \markdownLaTeXRowCounter=0%
    \markdownLaTeXRowTotal=#2%
    \markdownLaTeXColumnTotal=#3%
    \markdownLaTeXRenderTableRow
  }%
}}

\RequirePackage[colorlinks,linkcolor=black,citecolor=black, urlcolor=blue,unicode,plainpages=false]{hyperref}
\RequirePackage{lastpage}
\RequirePackage[backend=biber,style=gost-numeric,sorting=none]{biblatex}

%% ── Бібліографія: emdash → endash ───────────────────────────
%% Стиль gost-numeric ставить — (em-dash) між полями та діапазонами.
%% Звужуємо до – (en-dash) лише всередині списку літератури,
%% не чіпаючи решту документа.
\AtBeginBibliography{%
  \renewcommand{\textemdash}{\textendash}%
  \renewcommand{\bibrangedash}{\textendash}%
}

%% ── Інші пакети ─────────────────────────────────────────────
%% acronym: [nohyperlinks] прибирає попередження
%% "Hyper reference `acro:XXX' undefined" коли \ac{} не використовується
%% у тексті, а перелік є просто статичним списком.
\RequirePackage[nohyperlinks]{acronym}

\RequirePackage[toc,page]{appendix}
\renewcommand{\appendixpagename}{\MakeUppercase{Додатки}}
\renewcommand{\appendixtocname}{Додатки}
\RequirePackage{etoolbox}
\RequirePackage{csquotes}

%% ════════════════════════════════════════════════════════════
%%  ПОЛЯ РОБОТИ — заповнюються в thesis_info.tex
%%  (валідація винесена у tools/check.sh)
%% ════════════════════════════════════════════════════════════
\def\ThesisTitle      {Вкажіть назву роботи}
\def\ThesisAuthor     {Вкажіть прізвище ім'я по-батькові}
\def\ThesisSupervisor {Вкажіть наукового керівника}
\def\ThesisDept       {Вкажіть кафедру}
\def\ThesisFaculty    {Вкажіть факультет}
\def\ThesisUniversity {Вкажіть університет}
\def\ThesisSpecialty  {Вкажіть спеціальність}
\def\ThesisCity       {Київ}
\def\ThesisYear       {2025}
\def\ThesisKeywords   {ВКАЖІТЬ КЛЮЧОВІ СЛОВА}
\def\ThesisMeta       {вкажіть мету роботи}
\def\ThesisObject     {вкажіть об'єкт дослідження}
\def\ThesisSubject    {вкажіть предмет дослідження}
\def\ThesisMethods    {вкажіть методи дослідження}
\def\ThesisNovelty    {вкажіть наукову новизну}
\def\ThesisPractical  {вкажіть практичне значення}
\def\ThesisAprobation {}
\def\ThesisPublications{}

%% ════════════════════════════════════════════════════════════
%%  АВТОМАТИЧНИЙ ПІДРАХУНОК СТАТИСТИКИ
%%  • рис./табл./дод. — через хуки на оточення
%%  • джерела        — через \AtEveryBibitem (biblatex)
%%  • значення зберігаються в .aux, читаються на наступному
%%    проході (потрібна 2-га компіляція для коректного реферату)
%% ════════════════════════════════════════════════════════════
\newcounter{thesis@figcnt}
\newcounter{thesis@tabcnt}
\newcounter{thesis@refcnt}
\newcounter{thesis@appcnt}

\AtBeginEnvironment{figure}   {\stepcounter{thesis@figcnt}}
\AtBeginEnvironment{table}    {\stepcounter{thesis@tabcnt}}
\AtBeginEnvironment{longtable}{\stepcounter{thesis@tabcnt}}
\AtEveryBibitem              {\stepcounter{thesis@refcnt}}

%% Лічильник додатків: усередині env `appendices` тимчасово
%% перевизначаємо \chapter, щоб він спершу інкрементив лічильник,
%% а тоді викликав оригінальний \chapter. За межами env — без змін.
\AtBeginEnvironment{appendices}{%
  \let\thesis@orig@chapter\chapter
  \def\chapter{\stepcounter{thesis@appcnt}\thesis@orig@chapter}%
}
\AtEndEnvironment{appendices}{%
  \let\chapter\thesis@orig@chapter
}

\def\ThesisFigures   {?}
\def\ThesisTables    {?}
\def\ThesisSources   {?}
\def\ThesisAppendices{?}

%% Зберегти лічильники у .aux в кінці документа
\AtEndDocument{%
  \immediate\write\@auxout{%
    \noexpand\gdef\noexpand\ThesisFigures{\arabic{thesis@figcnt}}}%
  \immediate\write\@auxout{%
    \noexpand\gdef\noexpand\ThesisTables{\arabic{thesis@tabcnt}}}%
  \immediate\write\@auxout{%
    \noexpand\gdef\noexpand\ThesisSources{\arabic{thesis@refcnt}}}%
  \immediate\write\@auxout{%
    \noexpand\gdef\noexpand\ThesisAppendices{\arabic{thesis@appcnt}}}%
}

%% Метадані PDF + неперенесення посилань + придушення markdown warnings.
\AtBeginDocument{%
  \hypersetup{pdftitle={\ThesisTitle},pdfauthor={\ThesisAuthor}}%
  %% Прив'язати посилання [N] до попереднього слова неперенесним пробілом.
  \let\thesis@origcite\cite
  \def\cite{%
    \ifdim\lastskip>\z@\unskip\nobreakspace\fi
    \thesis@origcite}%
  \let\markdownWarning\@gobble
}

%% ════════════════════════════════════════════════════════════
%%  АВТОМАТИЧНО ЗГЕНЕРОВАНИЙ РЕФЕРАТ
%% ════════════════════════════════════════════════════════════
\newcommand{\makeThesisAbstract}{%
  \unnumberedchapter{Реферат}
  Дипломна робота магістра: \pageref{LastPage}~с.,
  \ThesisFigures~рис., \ThesisTables~табл.,
  \ThesisSources~джерел, \ThesisAppendices~додатків.

  \textbf{Ключові слова:} \ThesisKeywords.

  \textbf{Мета роботи}  \ThesisMeta.

  \textbf{Об'єкт дослідження} -- \ThesisObject.

  \textbf{Предмет дослідження} -- \ThesisSubject.

  \textbf{Методи дослідження:} \ThesisMethods.

  \textbf{Наукова новизна} отриманих результатів: \ThesisNovelty.

  \textbf{Практичне значення} результатів роботи: \ThesisPractical.%
}

\newcommand{\makeThesisIntroFields}{%
  \textbf{Мета і задачі дослідження.} Метою роботи є \ThesisMeta.

  \textbf{Об'єкт дослідження} -- \ThesisObject.

  \textbf{Предмет дослідження} -- \ThesisSubject.

  \textbf{Методи дослідження:} \ThesisMethods.

  \textbf{Наукова новизна} отриманих результатів: \ThesisNovelty.

  \textbf{Практичне значення} результатів роботи: \ThesisPractical.

  \ifblank{\ThesisAprobation}{}{\textbf{Апробація.} \ThesisAprobation.}
  \ifblank{\ThesisPublications}{}{\textbf{Публікації.} \ThesisPublications.}%
}

