\newcommand{\makeThesisTitlePage}{%
  \begin{titlepage}
    \begin{center}
      \textbf{\MakeUppercase{Міністерство освіти і науки України}}\\[6pt]
      \textbf{\MakeUppercase{\ThesisUniversity}}\\[4pt]
      \ThesisFaculty\\[4pt]\ThesisDept
      \vfill
      {\Large\bfseries КВАЛІФІКАЦІЙНА РОБОТА МАГІСТРА}\\[12pt]
      {\large на тему:}\\[8pt]
      {\Large\bfseries \guillemotleft\ThesisTitle\guillemotright}
      \vfill
      \begin{flushright}
        \begin{tabular}{ll}
          Виконав(ла): & \ThesisAuthor \\
          Спеціальність: & \ThesisSpecialty \\[8pt]
          Науковий керівник: & \ThesisSupervisor \\
        \end{tabular}
      \end{flushright}
      \vfill
      {\ThesisCity\ -- \ThesisYear}
    \end{center}
  \end{titlepage}%
}

%% ════════════════════════════════════════════════════════════
%%  ДОПОМІЖНІ КОМАНДИ
%% ════════════════════════════════════════════════════════════
\newcommand{\unnumberedchapter}[1]{%
  \chapter*{\MakeUppercase{#1}}%
  \addcontentsline{toc}{chapter}{#1}%
  \markboth{#1}{}%
}
\newcommand{\chapterconclusion}[1]{%
  \section*{Висновки до розділу~#1}%
  \addcontentsline{toc}{section}{Висновки до розділу~#1}%
}

